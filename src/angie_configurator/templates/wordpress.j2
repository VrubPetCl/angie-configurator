server {
{% for port in config.ports %}
    {% if port == 443 and ssl_paths %}
    listen {{ port }} ssl;
    {% else %}
    listen {{ port }};
    {% endif %}
{% endfor %}
    server_name {{ config.urls | join(' ') }};

{% if ssl_paths %}
    ssl_certificate {{ ssl_paths[0] }};
    ssl_certificate_key {{ ssl_paths[1] }};
{% endif %}

{% if config.maintenance %}
    location / {
        return 503;
    }
    {% if config.maint_page %}
    error_page 503 /{{ config.maint_page }};
    location = /{{ config.maint_page }} {
        root /var/www/html/maintenance;
        internal;
    }
    {% else %}
    error_page 503 /maintenance.html;
    location = /maintenance.html {
        root /var/www/html/maintenance;
        internal;
    }
    {% endif %}
{% else %}
{% if config.allow_cloudflare or config.allowed_ips %}
    {% if config.allow_cloudflare %}
    include /etc/angie-configurator/cloudflare-ips.conf;
    {% endif %}
    {% if config.allowed_ips %}
    {% for ip in config.allowed_ips %}
    allow {{ ip }};
    {% endfor %}
    {% endif %}
    deny all;
{% endif %}

    root /var/www/wordpress;
    index index.php index.html index.htm;

{% if config.caching and config.caching.purge_endpoint %}
    location /purge {
        allow 127.0.0.1;
        deny all;
        fastcgi_cache_purge WORDPRESS "$scheme$request_method$host$request_uri";
    }
{% endif %}

    location / {
{% if config.caching and config.caching.client_headers %}
        expires 30d;
        add_header Cache-Control "public, no-transform";
{% endif %}
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/var/run/php/php-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
{% if config.caching and config.caching.server_cache %}
        fastcgi_cache WORDPRESS;
        fastcgi_cache_valid 200 60m;
{% endif %}
    }

{% if config.locations %}
{% for loc_path, loc_config in config.locations.items() %}
    location {{ loc_path }} {
{% if loc_config.proxy_config %}
{% if loc_config.proxy_config.raw_config %}
        {{ loc_config.proxy_config.raw_config }}
{% else %}
        proxy_pass http://{{ loc_config.proxy_config.dest_addr }}:{{ loc_config.proxy_config.dest_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
{% endif %}
{% endif %}
    }
{% endfor %}
{% endif %}

{% endif %}
}
